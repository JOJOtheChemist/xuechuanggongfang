.nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.9); /* Solid background to avoid gaps */
  backdrop-filter: blur(10px);
  pointer-events: auto; /* Ensure clickable */
  z-index: 1000; /* Ensure tab bar is always on top */
  padding-bottom: env(safe-area-inset-bottom); /* Safe area for devices with bottom notch */
}

.nav-inner {
  height: 60px;
  background-color: transparent; /* Let nav handle background */
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 6px;
  box-shadow: 0 -2px 8px rgba(15, 23, 42, 0.1);
}

.nav-side {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.nav-side-full {
  width: 100%;
  padding-left: 0;
  padding-right: 0;
}

.nav-side-left {
  padding-right: 4px;
}

.nav-side-right {
  padding-left: 4px;
}

.nav-item {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.nav-icon-img {
  width: 18px;
  height: 18px;
  margin-bottom: 2px;
  opacity: 0.5;
  transition: opacity 0.2s;
}

.nav-item-active .nav-icon-img {
  opacity: 1;
}

.nav-text {
  max-width: 100%;
  font-size: 9px;
  color: #6b7280;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.nav-text-active {
  color: #4f46e5;
  font-weight: 600;
}

.nav-center-btn {
  width: 42px;
  height: 42px;
  border-radius: 21px;
  background-color: #0f172a;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  box-shadow: 0 8px 20px rgba(15, 23, 42, 0.5);
  border: 2px solid #f1f5f9;
}

.nav-center-icon-img {
  width: 28px;
  height: 28px;
}
