{
  "bsonType": "object",
  "description": "文章表",
  "required": [
    "title",
    "category_id"
  ],
  "permission": {
    "read": true,
    "create": true,
    "update": "'admin' in auth.role || auth.uid == doc.author_id",
    "delete": "'admin' in auth.role"
  },
  "properties": {
    "_id": {
      "description": "文章ID"
    },
    "category_id": {
      "bsonType": "string",
      "description": "所属业务板块ID",
      "label": "业务板块",
      "foreignKey": "business_categories._id"
    },
    "title": {
      "bsonType": "string",
      "description": "文章标题",
      "label": "标题",
      "trim": "both"
    },
    "summary": {
      "bsonType": "string",
      "description": "文章摘要",
      "label": "摘要"
    },
    "content": {
      "bsonType": "string",
      "description": "文章内容（富文本HTML）",
      "label": "内容"
    },
    "cover_image": {
      "bsonType": "string",
      "description": "封面图URL",
      "label": "封面图"
    },
    "author_id": {
      "bsonType": "string",
      "description": "作者ID",
      "foreignKey": "uni-id-users._id"
    },
    "author_name": {
      "bsonType": "string",
      "description": "作者名称",
      "label": "作者"
    },
    "stats": {
      "bsonType": "object",
      "description": "统计数据",
      "properties": {
        "views": {
          "bsonType": "int",
          "description": "浏览量",
          "default": 0
        },
        "likes": {
          "bsonType": "int",
          "description": "点赞数",
          "default": 0
        },
        "dislikes": {
          "bsonType": "int",
          "description": "踩数",
          "default": 0
        }
      }
    },
    "price_points": {
      "bsonType": "int",
      "description": "阅读所需积分，0 表示免费",
      "default": 5
    },
    "publish_time": {
      "bsonType": "timestamp",
      "description": "发布时间"
    },
    "tags": {
      "bsonType": "array",
      "description": "标签列表",
      "items": {
        "bsonType": "string"
      }
    },
    "attachments": {
      "bsonType": "array",
      "description": "附件/图集",
      "items": {
        "bsonType": "object"
      }
    },
    "create_date": {
      "bsonType": "timestamp",
      "description": "创建时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    },
    "update_date": {
      "bsonType": "timestamp",
      "description": "更新时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}