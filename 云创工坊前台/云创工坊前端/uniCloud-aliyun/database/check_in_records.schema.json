{
  "bsonType": "object",
  "description": "签到记录表",
  "required": ["user_id", "check_in_date"],
  "permission": {
    "read": "auth.uid == doc.user_id",
    "create": "auth.uid != null",
    "update": false,
    "delete": "auth.uid == doc.user_id"
  },
  "properties": {
    "_id": {
      "description": "记录ID"
    },
    "user_id": {
      "bsonType": "string",
      "description": "用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "check_in_date": {
      "bsonType": "string",
      "description": "签到日期 YYYY-MM-DD"
    },
    "create_date": {
      "bsonType": "timestamp",
      "description": "签到时间戳"
    }
  }
}
