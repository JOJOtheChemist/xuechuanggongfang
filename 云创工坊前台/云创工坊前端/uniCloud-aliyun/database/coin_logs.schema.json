{
  "bsonType": "object",
  "description": "新币流水记录表",
  "required": ["user_id", "amount", "type"],
  "permission": {
    "read": "auth.uid == doc.user_id || 'admin' in auth.role",
    "create": false,
    "update": false,
    "delete": "'admin' in auth.role"
  },
  "properties": {
    "_id": {
      "description": "流水ID"
    },
    "user_id": {
      "bsonType": "string",
      "description": "用户ID",
      "foreignKey": "uni-id-users._id"
    },
    "amount": {
      "bsonType": "double",
      "description": "变动金额（正数为增加，负数为减少）"
    },
    "type": {
      "bsonType": "string",
      "description": "流水类型",
      "enum": ["reward", "exchange", "income", "refund", "admin_adjust"]
    },
    "status": {
      "bsonType": "string",
      "description": "流水状态",
      "enum": ["processing", "success", "failed", "cancelled"],
      "default": "success"
    },
    "ref_id": {
      "bsonType": "string",
      "description": "关联业务ID（如兑换申请ID、任务ID等）"
    },
    "remark": {
      "bsonType": "string",
      "description": "备注说明"
    },
    "create_date": {
      "bsonType": "timestamp",
      "description": "创建时间"
    }
  }
}
