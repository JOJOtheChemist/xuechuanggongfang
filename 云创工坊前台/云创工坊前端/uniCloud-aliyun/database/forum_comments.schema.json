{
  "bsonType": "object",
  "description": "Campus forum comments",
  "required": [
    "post_id",
    "user_id",
    "user_name",
    "content"
  ],
  "permission": {
    "read": true,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "Comment id"
    },
    "post_id": {
      "bsonType": "string",
      "description": "Related post id",
      "foreignKey": "forum_posts._id"
    },
    "user_id": {
      "bsonType": "string",
      "description": "Author user id",
      "foreignKey": "uni-id-users._id"
    },
    "user_name": {
      "bsonType": "string",
      "description": "Author display name"
    },
    "user_avatar": {
      "bsonType": "string",
      "description": "Author avatar"
    },
    "content": {
      "bsonType": "string",
      "description": "Comment content"
    },
    "create_date": {
      "bsonType": "long",
      "description": "Created at (ms timestamp)"
    }
  }
}
