{
  "bsonType": "object",
  "description": "用户表扩展",
  "required": [
    "username"
  ],
  "permission": {
    "read": "auth.uid == doc._id || 'admin' in auth.role",
    "create": false,
    "update": "auth.uid == doc._id || 'admin' in auth.role",
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "用户ID"
    },
    "username": {
      "bsonType": "string",
      "description": "用户名"
    },
    "nickname": {
      "bsonType": "string",
      "description": "昵称"
    },
    "avatar": {
      "bsonType": "string",
      "description": "头像URL"
    },
    "mobile": {
      "bsonType": "string",
      "description": "手机号"
    },
    "email": {
      "bsonType": "string",
      "description": "邮箱"
    },
    "role": {
      "bsonType": "array",
      "description": "角色数组",
      "enum": [
        [
          "user"
        ],
        [
          "team_member"
        ],
        [
          "partner"
        ],
        [
          "admin"
        ],
        [
          "user",
          "team_member"
        ],
        [
          "user",
          "partner"
        ],
        [
          "team_member",
          "partner"
        ],
        [
          "user",
          "team_member",
          "partner"
        ]
      ]
    },
    "profile": {
      "bsonType": "object",
      "description": "用户详细资料（选填）",
      "properties": {
        "real_name": {
          "bsonType": "string",
          "description": "真实姓名"
        },
        "phone": {
          "bsonType": "string",
          "description": "联系电话"
        },
        "nation": {
          "bsonType": "string",
          "description": "民族"
        },
        "work_duration": {
          "bsonType": "string",
          "description": "工作期限",
          "enum": [
            "应届生",
            "1-3年",
            "3-5年",
            "5年以上"
          ]
        },
        "school": {
          "bsonType": "string",
          "description": "学校"
        },
        "enrollment_year": {
          "bsonType": "int",
          "description": "入学年份"
        },
        "is_student": {
          "bsonType": "bool",
          "description": "是否为学生"
        },
        "is_profile_completed": {
          "bsonType": "bool",
          "description": "资料是否已完善",
          "default": false
        }
      }
    },
    "team_info": {
      "bsonType": "object",
      "description": "团队成员信息",
      "properties": {
        "team_id": {
          "bsonType": "string",
          "description": "团队ID"
        },
        "team_name": {
          "bsonType": "string",
          "description": "团队名称"
        },
        "team_level": {
          "bsonType": "string",
          "description": "团队等级",
          "enum": [
            "初级",
            "中级",
            "高级"
          ]
        },
        "position": {
          "bsonType": "string",
          "description": "团队职位",
          "enum": [
            "组员",
            "组长",
            "主管"
          ]
        },
        "join_team_date": {
          "bsonType": "timestamp",
          "description": "加入团队时间"
        },
        "status": {
          "bsonType": "string",
          "description": "状态",
          "enum": [
            "active",
            "inactive",
            "frozen"
          ]
        },
        "invite_qrcode_url": {
          "bsonType": "string",
          "description": "该用户在当前团队的专属邀请小程序码URL"
        },
        "invite_scene": {
          "bsonType": "string",
          "description": "该邀请码绑定的scene（tid+inviter）"
        }
      }
    },
    "partner_info": {
      "bsonType": "object",
      "description": "合伙人信息",
      "properties": {
        "level": {
          "bsonType": "string",
          "description": "合伙人等级",
          "enum": [
            "初级合伙人",
            "中级合伙人",
            "高级合伙人"
          ]
        },
        "partner_id": {
          "bsonType": "string",
          "description": "合伙人编号"
        },
        "join_date": {
          "bsonType": "timestamp",
          "description": "加入时间"
        },
        "inviter_id": {
          "bsonType": "string",
          "description": "邀请人ID"
        },
        "team_count": {
          "bsonType": "int",
          "description": "团队人数",
          "default": 0
        },
        "total_profit": {
          "bsonType": "double",
          "description": "总收益",
          "default": 0
        },
        "status": {
          "bsonType": "string",
          "description": "状态",
          "enum": [
            "active",
            "inactive",
            "frozen"
          ]
        }
      }
    },
    "wallet": {
      "bsonType": "object",
      "description": "钱包信息",
      "properties": {
        "balance": {
          "bsonType": "double",
          "description": "余额",
          "default": 0
        },
        "frozen_balance": {
          "bsonType": "double",
          "description": "冻结金额",
          "default": 0
        },
        "total_income": {
          "bsonType": "double",
          "description": "总收入",
          "default": 0
        },
        "total_withdraw": {
          "bsonType": "double",
          "description": "总提现",
          "default": 0
        },
        "payment_qrcode": {
          "bsonType": "string",
          "description": "提现收款码URL"
        }
      }
    },
    "stats": {
      "bsonType": "object",
      "description": "统计数据",
      "properties": {
        "total_orders": {
          "bsonType": "int",
          "description": "总订单数",
          "default": 0
        },
        "total_sales": {
          "bsonType": "double",
          "description": "总销售额",
          "default": 0
        },
        "team_sales": {
          "bsonType": "double",
          "description": "团队销售额",
          "default": 0
        },
        "company_sales": {
          "bsonType": "double",
          "description": "公司销售额",
          "default": 0
        }
      }
    },
    "check_in": {
      "bsonType": "object",
      "description": "打卡信息",
      "properties": {
        "last_check_in_date": {
          "bsonType": "string",
          "description": "最后打卡日期 YYYY-MM-DD"
        },
        "streak_days": {
          "bsonType": "int",
          "description": "连续打卡天数",
          "default": 0
        },
        "total_check_in_days": {
          "bsonType": "int",
          "description": "累计打卡天数",
          "default": 0
        }
      }
    },
    "profile_edit": {
      "bsonType": "object",
      "description": "个人资料编辑相关信息（包含头像/昵称修改次数等）",
      "properties": {
        "avatar_nickname_changes": {
          "bsonType": "array",
          "description": "最近头像/昵称变更时间戳列表（毫秒）",
          "items": {
            "bsonType": "long"
          }
        }
      }
    },
    "create_date": {
      "bsonType": "timestamp",
      "description": "创建时间"
    },
    "update_date": {
      "bsonType": "timestamp",
      "description": "更新时间"
    }
  }
}